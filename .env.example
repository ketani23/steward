# Steward Environment Configuration
# Copy this file and set your values:
#   cp .env.example .env && chmod 600 .env

# =============================================================================
# Required
# =============================================================================

# Anthropic API key for LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Telegram Integration (required if using Telegram channel)
# =============================================================================

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Comma-delimited Telegram user IDs allowed to interact (deny-all if empty)
TELEGRAM_ALLOWED_USER_IDS=

# =============================================================================
# WhatsApp Integration (optional)
# =============================================================================

# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_APP_SECRET=
# WHATSAPP_VERIFY_TOKEN=

# =============================================================================
# PostgreSQL (defaults match docker-compose.yml)
# =============================================================================

POSTGRES_USER=steward
POSTGRES_PASSWORD=change_me_to_a_random_password
POSTGRES_DB=steward

# =============================================================================
# Steward Options (all optional — sensible defaults provided)
# =============================================================================

# Primary agent model
# STEWARD_MODEL=claude-sonnet-4-5-20250929

# Guardian review model
# STEWARD_GUARDIAN_MODEL=claude-haiku-4-5-20251001

# Log format: "pretty" (dev) or "json" (production)
# STEWARD_LOG_FORMAT=json

# Log level filter
# RUST_LOG=steward=info
